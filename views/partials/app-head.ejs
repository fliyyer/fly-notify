<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="<%= typeof description !== 'undefined' ? description : 'FlyNotify adalah gateway WhatsApp untuk push notification, API key management, dan monitoring pengiriman.' %>">
<meta name="theme-color" content="#f8f7f4">
<meta property="og:title" content="<%= typeof ogTitle !== 'undefined' ? ogTitle : (typeof title !== 'undefined' ? title : 'FlyNotify') %>">
<meta property="og:description" content="<%= typeof ogDescription !== 'undefined' ? ogDescription : (typeof description !== 'undefined' ? description : 'Gateway WhatsApp untuk mengirim push notification dari aplikasi kamu.') %>">
<meta property="og:type" content="website">
<meta property="og:image" content="/icons/flynotify-icon.svg">
<meta property="og:site_name" content="FlyNotify">
<title><%= typeof title !== 'undefined' ? title : 'FlyNotify' %></title>
<link rel="icon" type="image/svg+xml" href="/icons/favicon.svg">
<link rel="apple-touch-icon" href="/icons/flynotify-icon.svg">
<link rel="manifest" href="/site.webmanifest">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:wght@600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
