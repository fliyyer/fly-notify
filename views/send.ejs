<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/app-head', {
        title: 'Send Message - FlyNotify',
        description: 'Kirim dan tes pesan WhatsApp manual dari FlyNotify dengan payload yang bebas dikustom.'
    }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8f7f4; color: #1c1917; }
        h1, h2, h3 { font-family: 'Source Serif 4', serif; }
        .nav-link.active { background: #1f2937; color: white; }
        .nav-link.active i { color: #cbd5e1 !important; }
        .card { background: white; border: 1px solid #e7e5e4; border-radius: 24px; box-shadow: 0 10px 30px rgba(28, 25, 23, 0.05); }
        .field { width: 100%; border: 1px solid #d6d3d1; border-radius: 18px; background: white; padding: 0.95rem 1rem; outline: none; transition: border-color .15s, box-shadow .15s; }
        .field:focus { border-color: #1f2937; box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.08); }
        .field.is-error { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1); }
        .field-error-msg { color: #ef4444; font-size: 0.78rem; margin-top: 0.35rem; display: none; }
        .field-error-msg.show { display: block; }
        .btn-soft { border-radius: 9999px; padding: 0.9rem 1.25rem; font-weight: 600; transition: .2s ease; }
        .btn-soft:hover:not(:disabled) { transform: translateY(-1px); }
        .btn-soft:disabled { opacity: 0.6; cursor: not-allowed; }

        /* Mode tabs */
        .mode-tab { flex: 1; padding: 0.65rem 1rem; border-radius: 9999px; font-weight: 600; font-size: 0.875rem; transition: .2s; cursor: pointer; text-align: center; border: none; background: transparent; color: #78716c; }
        .mode-tab.active { background: #1f2937; color: white; }
        .mode-tab:hover:not(.active) { background: #f5f5f4; color: #1c1917; }

        /* Result items */
        .result-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0.75rem; border-radius: 12px; font-size: 0.85rem; }
        .result-item.ok { background: #f0fdf4; color: #166534; }
        .result-item.fail { background: #fef2f2; color: #991b1b; }

        /* Spinner */
        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner { width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.4); border-top-color: white; border-radius: 50%; animation: spin .7s linear infinite; display: inline-block; vertical-align: middle; margin-right: 6px; }
    </style>
</head>
<body class="min-h-screen">
    <%- include('partials/auth-guard') %>
    <div class="flex min-h-screen overflow-hidden">
        <%- include('partials/sidebar') %>
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
            <header class="border-b border-stone-200 bg-white px-4 py-5 sm:px-6 lg:px-8">
                <div class="flex items-start gap-3">
                    <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-stone-200 text-stone-700 lg:hidden" onclick="openSidebar()" aria-label="Open menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div>
                        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Send Message</h2>
                        <p class="mt-2 text-sm leading-6 text-stone-600 sm:text-base">Kirim pesan WhatsApp manual — custom message atau pakai template, bebas.</p>
                    </div>
                </div>
            </header>
            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.05fr_0.95fr]">
                    <section class="card p-6 sm:p-7">
                        <h3 class="text-3xl font-bold">Kirim Pesan</h3>
                        <p class="mt-1 text-stone-500 text-sm">Nomor tujuan wajib diisi. Isi pesan bisa langsung diketik <em>atau</em> pilih template sebagai titik awal.</p>

                        <!-- Mode Toggle -->
                        <div class="mt-5 flex gap-1 rounded-full bg-stone-100 p-1">
                            <button type="button" id="modeCustom" class="mode-tab active" onclick="setMode('custom')">
                                <i class="fas fa-pencil-alt mr-1.5"></i> Tulis Langsung
                            </button>
                            <button type="button" id="modeTpl" class="mode-tab" onclick="setMode('template')">
                                <i class="fas fa-file-alt mr-1.5"></i> Dari Template
                            </button>
                        </div>

                        <form id="pushForm" class="mt-6 space-y-4" novalidate>

                            <!-- Kirim dari device -->
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-stone-700">Kirim Dari Device <span class="text-red-500">*</span></label>
                                <select id="deviceId" class="field">
                                    <option value="auto">Otomatis (First Ready)</option>
                                </select>
                            </div>

                            <!-- Nomor tujuan -->
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-stone-700">Nomor Tujuan <span class="text-red-500">*</span></label>
                                <textarea id="numbers" rows="3" placeholder="Satu atau banyak nomor. Pisahkan dengan enter atau koma.&#10;Contoh: 628123456789, 628987654321" class="field"></textarea>
                                <p id="errNumbers" class="field-error-msg">Masukkan minimal satu nomor tujuan.</p>
                            </div>

                            <!-- Nama & App (opsional) -->
                            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-stone-700">Nama Penerima <span class="text-stone-400 font-normal">(opsional)</span></label>
                                    <input id="recipientName" placeholder="Untuk placeholder {name}" class="field">
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-stone-700">Nama App / Source <span class="text-stone-400 font-normal">(opsional)</span></label>
                                    <input id="appName" placeholder="Mis. Billing Service" class="field">
                                </div>
                            </div>

                            <!-- Template selector (hanya tampil di mode template) -->
                            <div id="templateSection" class="hidden">
                                <label class="mb-1.5 block text-sm font-medium text-stone-700">Pilih Template <span class="text-stone-400 font-normal">(opsional — bisa diedit setelah dipilih)</span></label>
                                <select id="templateId" class="field">
                                    <option value="">— Pilih template —</option>
                                </select>
                                <p class="mt-1.5 text-xs text-stone-400">Setelah memilih, isi pesan akan auto-terisi dan masih bisa kamu ubah.</p>
                            </div>

                            <!-- Isi pesan -->
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-stone-700">Isi Pesan <span class="text-red-500">*</span></label>
                                <textarea id="customMessage" rows="9" placeholder="Tulis pesan kamu di sini. Bebas format — emoji, baris baru, dsb." class="field"></textarea>
                                <p id="errMessage" class="field-error-msg">Isi pesan tidak boleh kosong.</p>
                            </div>

                            <!-- Variables JSON -->
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-stone-700">Variables JSON <span class="text-stone-400 font-normal">(opsional)</span></label>
                                <textarea id="variables" rows="3" placeholder='{"reference":"INV-88","status":"PAID"}' class="field font-mono text-sm"></textarea>
                                <p id="errVars" class="field-error-msg"></p>
                                <p class="mt-1.5 text-xs text-stone-400">Gunakan placeholder <code class="bg-stone-100 px-1 rounded">{key}</code> dalam pesan agar terisi otomatis dari sini.</p>
                            </div>

                            <button type="submit" id="submitBtn" class="btn-soft bg-stone-900 text-white w-full sm:w-auto">
                                <i class="fas fa-paper-plane mr-2"></i> Kirim Sekarang
                            </button>
                        </form>
                    </section>

                    <aside class="space-y-6">
                        <!-- Hasil -->
                        <div class="card p-6 sm:p-7">
                            <h3 class="text-2xl font-bold">Hasil Pengiriman</h3>
                            <div id="sendSummary" class="mt-4 min-h-[100px] rounded-2xl bg-stone-50 p-5 text-stone-500 text-sm flex items-center justify-center">
                                Belum ada pengiriman.
                            </div>
                            <div id="sendDetails" class="mt-3 space-y-2 hidden"></div>
                        </div>

                        <!-- Panduan -->
                       <div class="card p-6 sm:p-7">
                            <h3 class="text-2xl font-bold">Panduan</h3>

                            <ul class="mt-4 space-y-3 text-sm leading-6 text-stone-600 list-none">
                                
                                <li class="flex gap-3 items-start">
                                    <span class="flex-none w-5 h-5 mt-0.5 rounded-full bg-stone-100 flex items-center justify-center text-xs font-bold text-stone-500">
                                        1
                                    </span>
                                    <span>
                                        Isi nomor tujuan — satu atau banyak, pisahkan dengan enter atau koma.
                                    </span>
                                </li>

                                <li class="flex gap-3 items-start">
                                    <span class="flex-none w-5 h-5 mt-0.5 rounded-full bg-stone-100 flex items-center justify-center text-xs font-bold text-stone-500">
                                        2
                                    </span>
                                    <span>
                                        Mau nulis pesan langsung? Pilih tab <strong>Tulis Langsung</strong> — ketik bebas, langsung kirim.
                                    </span>
                                </li>

                                <li class="flex gap-3 items-start">
                                    <span class="flex-none w-5 h-5 mt-0.5 rounded-full bg-stone-100 flex items-center justify-center text-xs font-bold text-stone-500">
                                        3
                                    </span>
                                    <span>
                                        Mau pakai template? Pilih tab <strong>Dari Template</strong>, lalu pilih template — isi pesan akan otomatis terisi dan masih bisa diedit.
                                    </span>
                                </li>

                                <li class="flex gap-3 items-start">
                                    <span class="flex-none w-5 h-5 mt-0.5 rounded-full bg-stone-100 flex items-center justify-center text-xs font-bold text-stone-500">
                                        4
                                    </span>
                                    <span>
                                        Gunakan <code class="bg-stone-100 px-1 rounded">{name}</code>, 
                                        <code class="bg-stone-100 px-1 rounded">{app}</code>, atau key lain — isi melalui Variables JSON.
                                    </span>
                                </li>

                            </ul>
                        </div>
                    </aside>
                </div>
            </main>
        </div>
    </div>

    <script>
        let templates = [];
        let currentMode = 'custom';

        function logout() {
            localStorage.removeItem('wa_token');
            window.location.href = '/login';
        }

        document.querySelectorAll('.nav-link').forEach((link) => {
            if (link.href === window.location.href) link.classList.add('active');
        });

        function setMode(mode) {
            currentMode = mode;
            document.getElementById('modeCustom').classList.toggle('active', mode === 'custom');
            document.getElementById('modeTpl').classList.toggle('active', mode === 'template');
            document.getElementById('templateSection').classList.toggle('hidden', mode === 'custom');
        }

        async function loadTemplates() {
            try {
                const res = await fetch('/api/templates');
                templates = await res.json();
                const select = document.getElementById('templateId');
                select.innerHTML = '<option value="">— Pilih template —</option>' +
                    templates.map((item) => `<option value="${item.id}">${item.name}</option>`).join('');
            } catch (e) {
                // silently fail — user can still write custom message
            }
        }

        document.getElementById('templateId').addEventListener('change', () => {
            const val = document.getElementById('templateId').value;
            const selected = templates.find((item) => String(item.id) === val);
            if (selected) {
                document.getElementById('customMessage').value = selected.message;
                document.getElementById('customMessage').focus();
            }
        });

        function setFieldError(fieldId, errId, show) {
            const field = document.getElementById(fieldId);
            const err   = document.getElementById(errId);
            if (show) {
                field.classList.add('is-error');
                err.classList.add('show');
            } else {
                field.classList.remove('is-error');
                err.classList.remove('show');
            }
        }

        function setSummary(type, html) {
            const s = document.getElementById('sendSummary');
            const colorMap = {
                idle:    'bg-stone-50 text-stone-500',
                loading: 'bg-stone-50 text-stone-600',
                success: 'bg-emerald-50 text-emerald-800',
                warning: 'bg-amber-50 text-amber-800',
                error:   'bg-red-50 text-red-700'
            };
            s.className = `mt-4 min-h-[100px] rounded-2xl p-5 text-sm flex items-center justify-center text-center ${colorMap[type] || colorMap.idle}`;
            s.innerHTML = html;
        }

        document.getElementById('pushForm').addEventListener('submit', async (event) => {
            event.preventDefault();

            // --- Validate ---
            let valid = true;
            const numbersVal = document.getElementById('numbers').value.trim();
            const messageVal = document.getElementById('customMessage').value.trim();
            const varsRaw    = document.getElementById('variables').value.trim();

            setFieldError('numbers', 'errNumbers', !numbersVal);
            if (!numbersVal) valid = false;

            setFieldError('customMessage', 'errMessage', !messageVal);
            if (!messageVal) valid = false;

            let variables = {};
            if (varsRaw) {
                try {
                    variables = JSON.parse(varsRaw);
                    setFieldError('variables', 'errVars', false);
                } catch (e) {
                    document.getElementById('errVars').textContent = 'JSON tidak valid: ' + e.message;
                    setFieldError('variables', 'errVars', true);
                    valid = false;
                }
            }

            if (!valid) return;

            // --- Submit ---
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Mengirim…';
            setSummary('loading', '<i class="fas fa-circle-notch fa-spin mr-2"></i> Mengirim pesan…');
            document.getElementById('sendDetails').classList.add('hidden');
            document.getElementById('sendDetails').innerHTML = '';

            const payload = {
                appName:       document.getElementById('appName').value.trim(),
                name:          document.getElementById('recipientName').value.trim(),
                numbers:       document.getElementById('numbers').value,
                templateId:    (currentMode === 'template' && document.getElementById('templateId').value) ? document.getElementById('templateId').value : null,
                customMessage: document.getElementById('customMessage').value,
                variables,
                deviceId:      document.getElementById('deviceId').value
            };

            try {
                const res  = await fetch('/api/send', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(payload)
                });
                const data = await res.json();

                if (!data.success) {
                    setSummary('error', '<i class="fas fa-times-circle mr-2"></i>' + (data.error || 'Push gagal.'));
                } else {
                    const failed = data.results.filter((r) => !r.success);
                    const allOk  = failed.length === 0;

                    if (allOk) {
                        setSummary('success', `<i class="fas fa-check-circle mr-2"></i> Semua terkirim! <strong>${data.totalSent}/${data.total}</strong> pesan berhasil.`);
                    } else {
                        setSummary('warning', `<i class="fas fa-exclamation-triangle mr-2"></i> Terkirim <strong>${data.totalSent}/${data.total}</strong>. ${failed.length} gagal.`);
                    }

                    // Detail per nomor
                    if (data.results.length > 0) {
                        const details = document.getElementById('sendDetails');
                        details.classList.remove('hidden');
                        details.innerHTML = data.results.map((r) =>
                            `<div class="result-item ${r.success ? 'ok' : 'fail'}">
                                <i class="fas ${r.success ? 'fa-check' : 'fa-times'} fa-xs flex-none"></i>
                                <span class="font-mono font-medium">${r.phone}</span>
                                ${!r.success ? `<span class="ml-auto text-xs opacity-70">${r.error || 'Gagal'}</span>` : ''}
                            </div>`
                        ).join('');
                    }
                }
            } catch (e) {
                setSummary('error', '<i class="fas fa-wifi mr-2"></i> Koneksi gagal: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane mr-2"></i> Kirim Sekarang';
            }
        });

        // Clear error on input
        ['numbers', 'customMessage'].forEach((id) => {
            document.getElementById(id).addEventListener('input', () => {
                if (document.getElementById(id).value.trim()) {
                    document.getElementById(id).classList.remove('is-error');
                }
            });
        });

        async function loadDevices() {
            try {
                const res = await fetch('/api/devices');
                const devices = await res.json();
                const select = document.getElementById('deviceId');
                
                select.innerHTML = '<option value="auto">Otomatis (First Ready)</option>';
                
                devices.forEach(device => {
                    const statusText = device.status?.ready ? 'Connected' : 'Offline/Not Connected';
                    const option = document.createElement('option');
                    option.value = device.id;
                    option.textContent = `${device.name} (${device.phoneNumber ? '+' + device.phoneNumber : 'Not connected'}) [${statusText}]`;
                    if (!device.status?.ready) {
                        option.textContent += ' ❌';
                        option.disabled = true;
                    } else {
                        option.textContent += ' ✅';
                    }
                    select.appendChild(option);
                });
            } catch (e) {
                console.error('Failed to load devices:', e);
            }
        }

        loadTemplates();
        loadDevices();
    </script>
    <%- include('partials/app-shell-script') %>
</body>
</html>
