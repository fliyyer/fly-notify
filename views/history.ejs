<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/app-head', {
        title: 'History - FlyNotify',
        description: 'Lihat riwayat pengiriman pesan WhatsApp dari dashboard dan endpoint API FlyNotify.'
    }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8f7f4; color: #1c1917; }
        h1, h2, h3 { font-family: 'Source Serif 4', serif; }
        .nav-link.active { background: #1f2937; color: white; }
        .nav-link.active i { color: #cbd5e1 !important; }
        .card { background: white; border: 1px solid #e7e5e4; border-radius: 24px; box-shadow: 0 10px 30px rgba(28, 25, 23, 0.05); }
        .btn-soft { border-radius: 9999px; padding: 0.85rem 1.2rem; font-weight: 600; transition: .2s ease; }
        .btn-soft:hover { transform: translateY(-1px); }
    </style>
</head>
<body class="min-h-screen">
    <%- include('partials/auth-guard') %>
    <div class="flex min-h-screen overflow-hidden">
        <%- include('partials/sidebar') %>
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
            <header class="border-b border-stone-200 bg-white px-4 py-5 sm:px-6 lg:px-8">
                <div class="flex items-start gap-3">
                    <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-stone-200 text-stone-700 lg:hidden" onclick="openSidebar()" aria-label="Open menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div>
                        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Delivery History</h2>
                        <p class="mt-2 text-sm leading-6 text-stone-600 sm:text-base">Riwayat semua push yang dikirim dari dashboard maupun endpoint API.</p>
                    </div>
                </div>
            </header>
            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <section class="card p-6 sm:p-7">
                    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <h3 class="text-3xl font-bold">Push Log</h3>
                            <p class="mt-2 text-stone-600">Sorted terbaru ke terlama.</p>
                        </div>
                        <button onclick="loadNotifications()" class="btn-soft bg-stone-900 text-white">Refresh</button>
                    </div>
                    <div id="historyList" class="space-y-4"></div>
                </section>
            </main>
        </div>
    </div>

    <script>
        function logout() {
            localStorage.removeItem('wa_token');
            window.location.href = '/login';
        }
        document.querySelectorAll('.nav-link').forEach((link) => {
            if (link.href === window.location.href) link.classList.add('active');
        });
        async function loadNotifications() {
            const res = await fetch('/api/notifications');
            const notifications = await res.json();
            const container = document.getElementById('historyList');
            if (notifications.length === 0) {
                container.innerHTML = '<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4 font-medium">Belum ada log push.</div>';
                return;
            }
            container.innerHTML = notifications.map((item) => `
                <div class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div class="min-w-0">
                            <p class="text-xl font-semibold">${item.recipientName || item.bookingName || 'Unknown recipient'}</p>
                            <p class="mt-1 text-stone-600">${item.phone || '-'}</p>
                            <p class="mt-2 text-xs font-medium uppercase tracking-[0.16em] text-stone-500">${item.appName || item.source || 'manual'} • ${new Date(item.sentAt).toLocaleString('id-ID')}</p>
                        </div>
                        <span class="rounded-full bg-emerald-100 px-3 py-2 text-sm font-medium text-emerald-800">${item.status || 'sent'}</span>
                    </div>
                    <pre class="mt-4 whitespace-pre-wrap text-sm text-stone-600">${item.message || '-'}</pre>
                </div>
            `).join('');
        }
        loadNotifications();
    </script>
    <%- include('partials/app-shell-script') %>
</body>
</html>
