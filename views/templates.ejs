<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/app-head', {
        title: 'Templates - FlyNotify',
        description: 'Kelola template pesan WhatsApp reusable untuk FlyNotify.'
    }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8f7f4; color: #1c1917; }
        h1, h2, h3 { font-family: 'Source Serif 4', serif; }
        .nav-link.active { background: #1f2937; color: white; }
        .nav-link.active i { color: #cbd5e1 !important; }
        .card { background: white; border: 1px solid #e7e5e4; border-radius: 24px; box-shadow: 0 10px 30px rgba(28, 25, 23, 0.05); }
        .field { width: 100%; border: 1px solid #d6d3d1; border-radius: 18px; background: white; padding: 0.95rem 1rem; outline: none; }
        .field:focus { border-color: #1f2937; box-shadow: 0 0 0 3px rgba(31, 41, 55, 0.08); }
        .btn-soft { border-radius: 9999px; padding: 0.85rem 1.2rem; font-weight: 600; transition: .2s ease; }
        .btn-soft:hover { transform: translateY(-1px); }
    </style>
</head>
<body class="min-h-screen">
    <%- include('partials/auth-guard') %>
    <div class="flex min-h-screen overflow-hidden">
        <%- include('partials/sidebar') %>
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
            <header class="border-b border-stone-200 bg-white px-4 py-5 sm:px-6 lg:px-8">
                <div class="flex items-start gap-3">
                    <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-stone-200 text-stone-700 lg:hidden" onclick="openSidebar()" aria-label="Open menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div>
                        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Template Library</h2>
                        <p class="mt-2 text-sm leading-6 text-stone-600 sm:text-base">Simpan template generik untuk dashboard atau API.</p>
                    </div>
                </div>
            </header>
            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <div class="grid grid-cols-1 gap-6 xl:grid-cols-[0.9fr_1.1fr]">
                    <section class="card p-6 sm:p-7">
                        <h3 class="text-3xl font-bold">Template Baru</h3>
                        <form id="templateForm" class="mt-6 space-y-4">
                            <input id="templateName" required placeholder="Nama template" class="field">
                            <textarea id="templateMessage" required rows="12" placeholder="Isi pesan template" class="field"></textarea>
                            <button type="submit" class="btn-soft bg-stone-900 text-white">Simpan Template</button>
                        </form>
                    </section>
                    <section class="card p-6 sm:p-7">
                        <h3 class="text-3xl font-bold">Saved Templates</h3>
                        <div id="templateList" class="mt-6 space-y-4"></div>
                    </section>
                </div>
            </main>
        </div>
    </div>

    <script>
        function logout() {
            localStorage.removeItem('wa_token');
            window.location.href = '/login';
        }
        document.querySelectorAll('.nav-link').forEach((link) => {
            if (link.href === window.location.href) link.classList.add('active');
        });
        async function loadTemplates() {
            const res = await fetch('/api/templates');
            const templates = await res.json();
            const container = document.getElementById('templateList');
            if (templates.length === 0) {
                container.innerHTML = '<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4 font-medium">Belum ada template.</div>';
                return;
            }
            container.innerHTML = templates.map((item) => `
                <div class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <div class="min-w-0">
                            <p class="text-lg font-semibold">${item.name}</p>
                            <pre class="mt-3 whitespace-pre-wrap text-sm text-stone-600">${item.message}</pre>
                        </div>
                        <button onclick="deleteTemplate(${item.id})" class="btn-soft bg-stone-900 text-white">Delete</button>
                    </div>
                </div>
            `).join('');
        }
        async function deleteTemplate(id) {
            await fetch('/api/templates/' + id, { method: 'DELETE' });
            loadTemplates();
        }
        document.getElementById('templateForm').addEventListener('submit', async (event) => {
            event.preventDefault();
            await fetch('/api/templates', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: document.getElementById('templateName').value.trim(),
                    message: document.getElementById('templateMessage').value.trim()
                })
            });
            document.getElementById('templateForm').reset();
            loadTemplates();
        });
        loadTemplates();
    </script>
    <%- include('partials/app-shell-script') %>
</body>
</html>
