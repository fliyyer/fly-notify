<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/app-head', {
        title: 'Connect Bot - FlyNotify',
        description: 'Hubungkan device WhatsApp ke FlyNotify agar gateway siap menerima push notification.'
    }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8f7f4; color: #1c1917; }
        h1, h2, h3 { font-family: 'Source Serif 4', serif; }
        .nav-link.active { background: #1f2937; color: white; }
        .nav-link.active i { color: #cbd5e1 !important; }
        .card { background: white; border: 1px solid #e7e5e4; border-radius: 24px; box-shadow: 0 10px 30px rgba(28, 25, 23, 0.05); }
        .btn-soft { border-radius: 9999px; padding: 0.85rem 1.2rem; font-weight: 600; transition: .2s ease; }
        .btn-soft:hover { transform: translateY(-1px); }
    </style>
</head>
<body class="min-h-screen">
    <%- include('partials/auth-guard') %>
    <div class="flex min-h-screen overflow-hidden">
        <%- include('partials/sidebar') %>
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
            <header class="border-b border-stone-200 bg-white px-4 py-5 sm:px-6 lg:px-8">
                <div class="flex items-start gap-3">
                    <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-stone-200 text-stone-700 lg:hidden" onclick="openSidebar()" aria-label="Open menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div>
                        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Connect WhatsApp Bot</h2>
                        <p class="mt-2 text-sm leading-6 text-stone-600 sm:text-base">Hubungkan satu device WhatsApp agar gateway siap menerima push.</p>
                    </div>
                </div>
            </header>
            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <div class="grid grid-cols-1 gap-6 xl:grid-cols-[0.9fr_1.1fr]">
                    <section class="card p-6 sm:p-7">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Bot Status</p>
                        <div id="botBadge" class="mt-4 inline-flex rounded-full bg-stone-100 px-4 py-2 text-sm font-semibold text-stone-700">Checking...</div>
                        <p id="botMeta" class="mt-4 leading-7 text-stone-600"></p>
                        <p id="botError" class="hidden mt-4 rounded-2xl bg-red-50 p-4 text-sm font-medium text-red-700"></p>
                        <div class="mt-6 flex flex-wrap gap-3">
                            <button onclick="checkBotStatus()" class="btn-soft bg-stone-100 text-stone-700">Refresh</button>
                            <button onclick="logoutBot()" class="btn-soft bg-stone-900 text-white">Reset Session</button>
                        </div>
                        <div class="mt-6 rounded-3xl border border-stone-200 bg-stone-50 p-5">
                            <p class="font-semibold">Flow</p>
                            <ol class="mt-3 space-y-2 text-sm text-stone-600">
                                <li>1. Buka WhatsApp di HP.</li>
                                <li>2. Masuk ke Perangkat tertaut.</li>
                                <li>3. Pilih Tautkan perangkat.</li>
                                <li>4. Scan QR yang muncul di panel kanan.</li>
                            </ol>
                        </div>
                    </section>
                    <section class="card p-6 sm:p-7">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">QR Pairing</p>
                        <div id="qrContainer" class="hidden mt-5 text-center">
                            <img id="qrImage" class="mx-auto h-auto w-full max-w-[320px] rounded-3xl border border-stone-200 bg-white p-3" alt="WhatsApp QR">
                        </div>
                        <div id="readyBox" class="hidden mt-5 rounded-3xl bg-emerald-50 p-6">
                            <p class="text-2xl font-bold">Bot connected.</p>
                            <p class="mt-2 text-stone-700" id="connName">-</p>
                            <p class="text-stone-500" id="connNumber">-</p>
                        </div>
                        <div id="waitingBox" class="mt-5 rounded-3xl bg-stone-50 p-6">
                            <p class="font-medium text-stone-700">Menunggu QR atau status bot terbaru.</p>
                        </div>
                    </section>
                </div>
            </main>
        </div>
    </div>

    <script>
        function logout() {
            localStorage.removeItem('wa_token');
            window.location.href = '/login';
        }
        document.querySelectorAll('.nav-link').forEach((link) => {
            if (link.href === window.location.href) link.classList.add('active');
        });
        async function checkBotStatus() {
            const res = await fetch('/api/bot/status');
            const status = await res.json();
            const badge = document.getElementById('botBadge');
            const meta = document.getElementById('botMeta');
            const error = document.getElementById('botError');
            const qrContainer = document.getElementById('qrContainer');
            const qrImage = document.getElementById('qrImage');
            const waitingBox = document.getElementById('waitingBox');
            const readyBox = document.getElementById('readyBox');

            if (status.ready) {
                badge.className = 'mt-4 inline-flex rounded-full bg-emerald-100 px-4 py-2 text-sm font-semibold text-emerald-800';
                badge.textContent = 'CONNECTED';
                meta.textContent = 'Bot siap menerima push.';
                error.classList.add('hidden');
                qrContainer.classList.add('hidden');
                waitingBox.classList.add('hidden');
                readyBox.classList.remove('hidden');
                document.getElementById('connName').textContent = status.info?.name || 'Unknown';
                document.getElementById('connNumber').textContent = status.info?.number ? '+' + status.info.number : '-';
            } else if (status.hasQR) {
                badge.className = 'mt-4 inline-flex rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-800';
                badge.textContent = 'SCAN QR NOW';
                meta.textContent = 'Gunakan WhatsApp HP untuk pair perangkat.';
                error.classList.add('hidden');
                qrImage.src = status.qr || '';
                qrContainer.classList.remove('hidden');
                waitingBox.classList.remove('hidden');
                readyBox.classList.add('hidden');
            } else {
                badge.className = 'mt-4 inline-flex rounded-full bg-stone-200 px-4 py-2 text-sm font-semibold text-stone-700';
                badge.textContent = 'OFFLINE';
                meta.textContent = 'Belum terhubung.';
                qrContainer.classList.add('hidden');
                readyBox.classList.add('hidden');
                waitingBox.classList.remove('hidden');
                if (status.error) {
                    error.textContent = status.error;
                    error.classList.remove('hidden');
                } else {
                    error.classList.add('hidden');
                }
            }
        }
        async function logoutBot() {
            await fetch('/api/bot/logout', { method: 'POST' });
            setTimeout(checkBotStatus, 1500);
        }
        const socket = io();
        socket.on('qr', checkBotStatus);
        socket.on('ready', checkBotStatus);
        socket.on('status', checkBotStatus);
        checkBotStatus();
    </script>
    <%- include('partials/app-shell-script') %>
</body>
</html>
