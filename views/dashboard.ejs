<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/app-head', {
        title: 'Dashboard - FlyNotify',
        description: 'Dashboard FlyNotify untuk koneksi WhatsApp, API key, metrik, dan integrasi aplikasi client.'
    }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f8f7f4; color: #1c1917; }
        h1, h2, h3 { font-family: 'Source Serif 4', serif; }
        .nav-link.active { background: #1f2937; color: white; }
        .nav-link.active i { color: #cbd5e1 !important; }
        .card { background: white; border: 1px solid #e7e5e4; border-radius: 24px; box-shadow: 0 10px 30px rgba(28, 25, 23, 0.05); }
        .btn-soft { border-radius: 9999px; padding: 0.85rem 1.2rem; font-weight: 600; transition: .2s ease; }
        .btn-soft:hover { transform: translateY(-1px); }
    </style>
</head>
<body class="min-h-screen">
    <%- include('partials/auth-guard') %>
    <div class="flex min-h-screen overflow-hidden">
        <%- include('partials/sidebar') %>
        <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
            <header class="border-b border-stone-200 bg-white px-4 py-5 sm:px-6 lg:px-8">
                <div class="flex items-start gap-3">
                    <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-stone-200 text-stone-700 lg:hidden" onclick="openSidebar()" aria-label="Open menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div>
                        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Gateway Dashboard</h2>
                        <p class="mt-2 text-sm leading-6 text-stone-600 sm:text-base">Satu panel FlyNotify untuk koneksi bot, API key, metrik, dan contoh integrasi.</p>
                    </div>
                </div>
            </header>
            <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8">
                <section class="mb-6 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
                    <div class="card p-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Total Sent</p>
                        <p id="statTotalSent" class="mt-4 text-5xl font-bold tracking-tight">0</p>
                    </div>
                    <div class="card p-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Sent Today</p>
                        <p id="statTodaySent" class="mt-4 text-5xl font-bold tracking-tight">0</p>
                    </div>
                    <div class="card p-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">API Keys</p>
                        <p id="statApiKeys" class="mt-4 text-5xl font-bold tracking-tight">0</p>
                    </div>
                    <div class="card p-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Templates</p>
                        <p id="statTemplates" class="mt-4 text-5xl font-bold tracking-tight">0</p>
                    </div>
                </section>

                <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.15fr_0.85fr]">
                    <section class="space-y-6">
                        <div class="card p-6 sm:p-7">
                            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Bot Runtime</p>
                                    <h3 class="mt-2 text-3xl font-bold">Koneksi WhatsApp</h3>
                                </div>
                                <div class="flex flex-wrap gap-3">
                                    <a href="/scan" class="btn-soft bg-emerald-50 text-emerald-800">Open Connect Page</a>
                                    <button onclick="logoutBot()" class="btn-soft bg-stone-900 text-white">Reset Session</button>
                                </div>
                            </div>
                            <div class="mt-6 grid gap-6 md:grid-cols-[0.7fr_1.3fr]">
                                <div>
                                    <div id="botBadge" class="inline-flex rounded-full px-4 py-2 text-sm font-semibold bg-stone-100 text-stone-700">Checking...</div>
                                    <p id="botMeta" class="mt-4 text-sm leading-6 text-stone-600"></p>
                                    <p id="botError" class="hidden mt-4 rounded-2xl bg-red-50 p-4 text-sm font-medium text-red-700"></p>
                                </div>
                                <div id="qrContainer" class="hidden">
                                    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Scan this QR</p>
                                    <img id="qrImage" class="card h-[280px] w-[280px] bg-white p-3" alt="WhatsApp QR" />
                                </div>
                            </div>
                        </div>

                        <div class="card p-6 sm:p-7">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">API Keys</p>
                                <h3 class="mt-2 text-3xl font-bold">Generate key untuk app client</h3>
                                <p class="mt-2 text-sm text-stone-600">Generate hanya aktif saat bot WhatsApp sudah connected.</p>
                            </div>
                            <form id="keyForm" class="mt-6 flex flex-col gap-3 md:flex-row">
                                <input id="keyName" placeholder="Nama app, tenant, atau partner" class="flex-1 rounded-full border border-stone-300 bg-white px-5 py-3 outline-none">
                                <button id="generateKeyBtn" type="submit" class="btn-soft bg-emerald-600 text-white">Generate API Key</button>
                            </form>
                            <div id="keyFeedback" class="hidden mt-4 rounded-2xl p-4 text-sm font-medium"></div>
                            <div id="keyList" class="mt-6 space-y-4"></div>
                        </div>
                    </section>

                    <aside class="space-y-6">
                        <div class="card p-6 sm:p-7">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">POST /api/push</p>
                            <pre id="apiSnippet" class="mt-4 overflow-auto rounded-2xl bg-stone-900 p-5 text-xs whitespace-pre-wrap text-stone-100">curl -X POST http://localhost:3000/api/push \
  -H "Content-Type: application/json" \
  -H "x-api-key: YOUR_KEY" \
  -d '{
    "to": "+14155550123",
    "recipientName": "Alya",
    "message": "Halo {name}, status terbaru sudah ready.",
    "variables": { "name": "Alya" }
  }'</pre>
                        </div>

                        <div class="card p-6 sm:p-7">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Latest Delivery</p>
                            <div id="recentHistory" class="mt-4 space-y-3"></div>
                        </div>
                    </aside>
                </div>
            </main>
        </div>
    </div>

    <script>
        function logout() {
            localStorage.removeItem('wa_token');
            window.location.href = '/login';
        }

        document.querySelectorAll('.nav-link').forEach((link) => {
            if (link.href === window.location.href) link.classList.add('active');
        });

        async function loadStats() {
            const res = await fetch('/api/stats');
            const stats = await res.json();
            document.getElementById('statTotalSent').textContent = stats.totalSent || 0;
            document.getElementById('statTodaySent').textContent = stats.todaySent || 0;
            document.getElementById('statApiKeys').textContent = stats.apiKeyCount || 0;
            document.getElementById('statTemplates').textContent = stats.templateCount || 0;
        }

        async function loadBotStatus() {
            const res = await fetch('/api/bot/status');
            const status = await res.json();
            const badge = document.getElementById('botBadge');
            const meta = document.getElementById('botMeta');
            const error = document.getElementById('botError');
            const qrContainer = document.getElementById('qrContainer');
            const qrImage = document.getElementById('qrImage');
            const keyButton = document.getElementById('generateKeyBtn');
            const keyName = document.getElementById('keyName');

            if (status.ready) {
                badge.className = 'inline-flex rounded-full px-4 py-2 text-sm font-semibold bg-emerald-100 text-emerald-800';
                badge.textContent = 'BOT CONNECTED';
                meta.textContent = (status.info?.name || 'Unknown') + ' / +' + (status.info?.number || '-');
                error.classList.add('hidden');
                error.textContent = '';
                qrContainer.classList.add('hidden');
                keyButton.disabled = false;
                keyName.disabled = false;
            } else if (status.hasQR) {
                badge.className = 'inline-flex rounded-full px-4 py-2 text-sm font-semibold bg-amber-100 text-amber-800';
                badge.textContent = 'WAITING FOR QR SCAN';
                meta.textContent = 'Buka WhatsApp > Perangkat tertaut > scan QR ini.';
                error.classList.add('hidden');
                error.textContent = '';
                qrImage.src = status.qr || '';
                qrContainer.classList.remove('hidden');
                keyButton.disabled = true;
                keyName.disabled = true;
            } else {
                badge.className = 'inline-flex rounded-full px-4 py-2 text-sm font-semibold bg-stone-200 text-stone-700';
                badge.textContent = 'BOT OFFLINE';
                meta.textContent = 'Bot belum siap menerima push.';
                qrContainer.classList.add('hidden');
                keyButton.disabled = true;
                keyName.disabled = true;
                if (status.error) {
                    error.textContent = status.error;
                    error.classList.remove('hidden');
                } else {
                    error.classList.add('hidden');
                    error.textContent = '';
                }
            }
        }

        async function loadKeys() {
            const res = await fetch('/api/keys');
            const keys = await res.json();
            const list = document.getElementById('keyList');
            if (keys.length === 0) {
                list.innerHTML = '<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4 font-medium">Belum ada API key.</div>';
                return;
            }

            list.innerHTML = keys.map((item) => `
                <div class="rounded-3xl border border-stone-200 bg-stone-50 p-5">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                        <div class="min-w-0">
                            <p class="text-lg font-semibold">${item.name}</p>
                            <p class="mt-1 text-xs font-medium uppercase tracking-[0.16em] text-stone-500">Created ${new Date(item.createdAt).toLocaleString('id-ID')}</p>
                            <p class="mt-1 text-xs text-stone-500">Last used ${item.lastUsedAt ? new Date(item.lastUsedAt).toLocaleString('id-ID') : 'never'}</p>
                            <code class="mt-3 block overflow-auto rounded-2xl bg-stone-900 p-4 text-xs text-stone-100">${item.key}</code>
                        </div>
                        <div class="flex flex-wrap gap-3">
                            <button onclick="copyKey('${item.key}')" class="btn-soft bg-emerald-50 text-emerald-800">Copy</button>
                            <button onclick="copyExpressExample('${item.key}', '${item.name.replace(/'/g, "\\'")}')" class="btn-soft bg-stone-100 text-stone-700">Copy Express Example</button>
                            <button onclick="deleteKey(${item.id})" class="btn-soft bg-stone-900 text-white">Delete</button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        async function loadHistory() {
            const res = await fetch('/api/notifications');
            const items = await res.json();
            const container = document.getElementById('recentHistory');
            if (items.length === 0) {
                container.innerHTML = '<div class="rounded-3xl border border-stone-200 bg-stone-50 p-4 font-medium">Belum ada riwayat push.</div>';
                return;
            }

            container.innerHTML = items.slice(0, 4).map((item) => `
                <div class="rounded-3xl border border-stone-200 bg-stone-50 p-4">
                    <p class="font-semibold">${item.recipientName || item.bookingName || 'Unknown'}</p>
                    <p class="mt-1 text-sm text-stone-600">${item.phone || '-'}</p>
                    <p class="mt-2 text-xs font-medium uppercase tracking-[0.16em] text-stone-500">${item.appName || item.source || 'manual'} • ${new Date(item.sentAt).toLocaleString('id-ID')}</p>
                </div>
            `).join('');
        }

        async function logoutBot() {
            await fetch('/api/bot/logout', { method: 'POST' });
            setTimeout(loadBotStatus, 1500);
        }

        async function deleteKey(id) {
            await fetch('/api/keys/' + id, { method: 'DELETE' });
            loadKeys();
            loadStats();
        }

        async function copyKey(key) {
            await navigator.clipboard.writeText(key);
        }

        async function copyExpressExample(key, appName) {
            const example = `const express = require('express');
const fetch = global.fetch;

const app = express();
app.use(express.json());

app.post('/send-whatsapp', async (req, res) => {
  const response = await fetch('http://localhost:3000/api/push', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': '${key}'
    },
    body: JSON.stringify({
      to: req.body.to,
      recipientName: req.body.recipientName,
      message: req.body.message,
      variables: req.body.variables || {}
    })
  });

  const result = await response.json();
  res.status(response.status).json(result);
});

app.listen(4000, () => {
  console.log('Client app ready for ${appName}');
});`;
            await navigator.clipboard.writeText(example);
        }

        document.getElementById('keyForm').addEventListener('submit', async (event) => {
            event.preventDefault();
            const name = document.getElementById('keyName').value.trim();
            const feedback = document.getElementById('keyFeedback');
            const res = await fetch('/api/keys', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name })
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('keyName').value = '';
                feedback.className = 'mt-4 rounded-2xl bg-emerald-50 p-4 text-sm font-medium text-emerald-700';
                feedback.textContent = 'API key berhasil dibuat dan siap dipakai oleh Express client.';
                feedback.classList.remove('hidden');
                loadKeys();
                loadStats();
            } else {
                feedback.className = 'mt-4 rounded-2xl bg-red-50 p-4 text-sm font-medium text-red-700';
                feedback.textContent = data.error || 'Gagal generate API key.';
                feedback.classList.remove('hidden');
            }
        });

        const socket = io();
        socket.on('qr', loadBotStatus);
        socket.on('ready', loadBotStatus);
        socket.on('status', loadBotStatus);

        loadStats();
        loadBotStatus();
        loadKeys();
        loadHistory();
    </script>
    <%- include('partials/app-shell-script') %>
</body>
</html>
